{
  "name": "magicknife-saas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev:local": "concurrently -n backend,web -c blue,green \"npm run backend\" \"vite\"",
    "dev": "npm run dev:local",
    "dev:proxy": "node proxy-server.cjs",
    "dev:both": "concurrently -n backend,web,proxy -c blue,green,magenta \"npm run backend\" \"vite\" \"npm run dev:proxy\"",
    "backend": "cd backend && npm start",
    "sync-atlas": "cd backend && npm run sync-atlas",
    "cms": "concurrently -n backend,web -c blue,green \"npm run backend\" \"vite\"",
    "live": "start https://themagicknife.com/",
    "server": "cd server && npm run dev",
    "full": "concurrently \"npm run cms\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "concurrently": "^9.2.1",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "http-proxy": "^1.18.1",
    "open": "^11.0.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.10"
  }
}
